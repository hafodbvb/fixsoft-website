---
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';

import blueprints from '@images/blueprints-image.avif';
import personWorking from '@images/person-working.avif';
import beforeAfter from '@images/before-after.avif';
import constructionWorkers from '@images/construction-workers.avif';
import aerialView from '@images/aerial-view.avif';
import usingTools from '@images/using-tools.avif';
import progressBuilding from '@images/progress-building.avif';
import underConstruction from '@images/under-construction.avif';
import { SITE } from '@data/constants';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'Web & Mobile Development',
    subTitle:
      'We build modern, high-performance websites and mobile applications tailored to your business. From professional landing pages and e-commerce platforms to complex web portals — our team delivers clean, fast, and scalable solutions that work across all devices. Android and iOS apps built with the latest frameworks.',
    single: false,
    imgOne: blueprints,
    imgOneAlt: 'Web development planning and wireframes',
    imgTwo: personWorking,
    imgTwoAlt: 'Developer working on a project',
  },
  {
    isRightSection: false,
    title: 'FixSoftRepair — Repair Shop Management System',
    subTitle:
      'Our flagship product FixSoftRepair is a complete desktop solution for managing any type of repair shop. Covers repair tracking, customer management, inventory, POS sales, invoicing, staff & payroll, installment sales, and even a built-in Zakat calculator. Works fully offline with free lifetime updates.',
    img: beforeAfter,
    imgAlt: 'FixSoftRepair system interface',
    btnExists: true,
    btnTitle: 'Explore FixSoftRepair',
    btnURL: '/products',
  },
  {
    isRightSection: true,
    title: 'Custom Enterprise Software',
    subTitle:
      'Every business has unique workflows. We design and develop fully custom software and enterprise systems built around your exact operational needs — ERP systems, inventory platforms, HR tools, financial dashboards, and more. Scalable architecture, secure data handling, and ongoing technical support included.',
    single: false,
    imgOne: constructionWorkers,
    imgOneAlt: 'Team planning a custom software system',
    imgTwo: aerialView,
    imgTwoAlt: 'Enterprise software architecture overview',
  },
  {
    isRightSection: false,
    title: 'SaaS Products & Cloud Platforms',
    subTitle:
      'Beyond custom development, FixSoft builds and delivers ready-made SaaS products designed for specific industries. If you need a multi-tenant platform, subscription-based tool, or cloud-hosted solution — our team has the expertise to take your idea from concept to a production-ready product.',
    img: usingTools,
    imgAlt: 'SaaS platform development by FixSoft',
  },
  {
    isRightSection: true,
    title: 'Technical Support & Maintenance',
    subTitle:
      'Our relationship does not end at delivery. Every product and project comes with dedicated post-launch support. We provide bug fixes, feature updates, performance optimization, and priority response for critical issues. Long-term maintenance contracts available for teams that need a reliable technology partner.',
    single: false,
    imgOne: progressBuilding,
    imgOneAlt: 'Technical support team',
    imgTwo: underConstruction,
    imgTwoAlt: 'Software maintenance and updates',
    btnExists: true,
    btnTitle: 'Contact Us',
    btnURL: '/contact',
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  'FixSoft delivers professional software services — web & mobile development, custom enterprise systems, SaaS products, and the FixSoftRepair management system.';
const ogTitle = 'Software Services | FixSoft';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://fixsoft.dz/services',
    url: 'https://fixsoft.dz/services',
    name: 'Software Services | FixSoft',
    description: 'Professional software services by FixSoft — web, mobile, enterprise, and SaaS.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://fixsoft.dz',
      name: 'FixSoft',
      description: 'Professional software solutions by FixSoft.',
    },
    inLanguage: 'en-US',
  }}
>
  <MainSection
    title="Professional Software Solutions for Every Business"
    subTitle="At FixSoft, we build digital solutions that help businesses operate faster and smarter. From custom software to ready-made products, our experienced team is dedicated to delivering quality at every stage of your project."
    btnExists={true}
    btnTitle="Request a Free Consultation"
    btnURL="/contact"
  />
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  <FeaturesStats
    title="By the Numbers"
    subTitle="Our commitment to quality is reflected in every project we deliver. FixSoft is trusted by repair shops and businesses across Algeria."
    mainStatTitle="98%"
    mainStatSubTitle="of our clients rate their experience with FixSoft as excellent"
    stats={[
      {
        stat: '200+',
        description: 'repair shops powered by FixSoftRepair',
      },
      {
        stat: '5+',
        description: 'years of professional software development',
      },
      {
        stat: '3x',
        description: 'faster operations reported by FixSoftRepair users',
      },
    ]}
  />
</MainLayout>
