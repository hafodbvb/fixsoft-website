---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';

const pageTitle = `FixSoftMobile | ${SITE.title}`;

const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3"/>`,
    title: 'Suivi à distance',
    desc: 'Surveillez l\'état de toutes les réparations en temps réel depuis votre smartphone, où que vous soyez.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.653-4.655m5.8-5.8 3.072-3.072a1.5 1.5 0 0 0 0-2.121l-1.414-1.414a1.5 1.5 0 0 0-2.121 0L9.586 6.343"/>`,
    title: 'Gestion des réparations',
    desc: 'Ajoutez, modifiez et mettez à jour les fiches de réparation directement depuis l\'application mobile.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5ZM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5ZM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 13.5 9.375v-4.5Z"/>`,
    title: 'Scanner Barcode & QR',
    desc: 'Scannez les codes-barres et QR codes des appareils et pièces détachées pour une identification instantanée.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"/>`,
    title: 'Ventes & Caisse',
    desc: 'Enregistrez les ventes et les transactions directement depuis votre téléphone, synchronisées avec le logiciel principal.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/>`,
    title: 'Notifications en temps réel',
    desc: 'Recevez des alertes instantanées sur l\'avancement des réparations, les paiements et les nouvelles demandes.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/>`,
    title: 'Sécurisé & Synchronisé',
    desc: 'Toutes vos données sont synchronisées en temps réel avec FixSoftRepair, avec chiffrement de bout en bout.',
  },
];
---

<MainLayout
  lang="fr"
  title={pageTitle}
  customDescription="FixSoftMobile — L'application mobile compagnon de FixSoftRepair. Gérez votre atelier à distance, scannez les codes, suivez les réparations."
  customOgTitle="FixSoftMobile | Application Mobile FixSoft"
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://fixsoft-website.vercel.app/fr/products/fixsoftmobile',
    url: 'https://fixsoft-website.vercel.app/fr/products/fixsoftmobile',
    name: 'FixSoftMobile | FixSoft',
    description: 'Application mobile compagnon de FixSoftRepair.',
    isPartOf: { '@type': 'WebSite', url: 'https://fixsoft-website.vercel.app', name: 'FixSoft' },
    inLanguage: 'fr',
  }}
>

  {/* ── Hero ── */}
  <div class="mx-auto max-w-[85rem] px-4 pt-14 pb-10 sm:px-6 lg:px-8 2xl:max-w-full">
    <div class="flex flex-col items-center gap-6 text-center lg:flex-row lg:justify-between lg:text-start">
      <div class="max-w-2xl">
        <img src="/fixsoftmobile-logo.png" alt="FixSoftMobile" class="-mb-12 -ml-14 w-[26rem] dark:brightness-90 lg:w-[32rem]" />
        <p class="mt-2 text-lg text-neutral-600 dark:text-neutral-400">
          L'application compagnon de FixSoftRepair. Gérez votre atelier depuis votre poche — suivi à distance, scanner intégré, ventes et notifications en temps réel.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4 lg:justify-start">
          <a href="#download"
            class="inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-6 py-3 text-sm font-bold text-neutral-900 transition hover:bg-cyan-400">
            <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
            Télécharger l'application
          </a>
          <a href="/fr/products"
            class="inline-flex items-center gap-2 rounded-xl border border-neutral-300 px-6 py-3 text-sm font-semibold text-neutral-700 transition hover:border-cyan-500 hover:text-cyan-600 dark:border-neutral-600 dark:text-neutral-300 dark:hover:border-cyan-500 dark:hover:text-cyan-400">
            Voir FixSoftRepair →
          </a>
        </div>
      </div>

      {/* Phone image */}
      <div class="shrink-0">
        <img src="/phone.png" alt="FixSoftMobile App" class="w-80 drop-shadow-2xl lg:w-96 lg:-ml-8" />
      </div>
    </div>
  </div>

  {/* ── Stats ── */}
  <div class="mx-auto max-w-[85rem] px-4 pb-10 sm:px-6 lg:px-8 2xl:max-w-full">
    <div class="grid grid-cols-2 divide-x divide-neutral-200 rounded-2xl border border-neutral-200 bg-white dark:divide-neutral-700 dark:border-neutral-700 dark:bg-neutral-800/40 sm:grid-cols-4">
      {[
        { val: 'Android', label: 'Compatible' },
        { val: 'iOS', label: 'Compatible' },
        { val: '100%', label: 'Synchronisé avec FixSoftRepair' },
        { val: 'Gratuit', label: 'Pour les abonnés FixSoftRepair PLUS' },
      ].map(s => (
        <div class="flex flex-col items-center justify-center px-6 py-7 text-center">
          <span class="text-2xl font-extrabold text-blue-600 dark:text-cyan-400">{s.val}</span>
          <span class="mt-1 text-xs text-neutral-500 dark:text-neutral-400">{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  {/* ── Features ── */}
  <div class="mx-auto max-w-[85rem] px-4 pb-14 sm:px-6 lg:px-8 2xl:max-w-full">
    <div class="mb-10 text-center">
      <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-100">Tout ce dont vous avez besoin, dans votre poche</h2>
      <p class="mt-3 text-neutral-500 dark:text-neutral-400">FixSoftMobile est conçu pour travailler en parfaite harmonie avec FixSoftRepair.</p>
    </div>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map(f => (
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 transition hover:border-cyan-500/50 hover:shadow-lg hover:shadow-cyan-500/5 dark:border-neutral-700 dark:bg-neutral-800/40">
          <div class="mb-4 flex size-12 items-center justify-center rounded-xl bg-cyan-500/10">
            <svg class="size-6 text-cyan-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={f.icon}/>
          </div>
          <h3 class="mb-2 font-bold text-neutral-800 dark:text-neutral-100">{f.title}</h3>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>

  {/* ── Download ── */}
  <div id="download" class="mx-auto max-w-[85rem] px-4 pb-20 sm:px-6 lg:px-8 2xl:max-w-full">
    <div class="rounded-3xl px-8 py-14 sm:px-14 lg:px-20" style="background: linear-gradient(135deg, #0f172a 0%, #0c2340 40%, #0e3a52 70%, #0f172a 100%)">
      <div class="flex flex-col items-center gap-10 text-center lg:flex-row lg:justify-between lg:text-start">
        <div class="max-w-lg">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">Téléchargez FixSoftMobile</h2>
          <p class="mt-3 text-neutral-400">Disponible sur Android et iOS. Gratuit pour tous les utilisateurs actifs de FixSoftRepair.</p>
          <div class="mt-6 flex flex-wrap justify-center gap-3 lg:justify-start">
            <a href="https://github.com/hafodbvb/fixsoft-website/releases/download/V2/FixSoftMobileV2.apk"
              download
              class="flex items-center gap-3 rounded-xl bg-cyan-500 px-6 py-3.5 text-sm font-bold text-neutral-900 transition hover:bg-cyan-400 active:scale-[.98]">
              <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/>
              </svg>
              Télécharger l'APK Android
            </a>
            <button disabled
              class="flex items-center gap-3 rounded-xl border border-white/20 bg-white/5 px-5 py-3 opacity-50 cursor-not-allowed backdrop-blur-sm">
              <svg class="size-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75M7.5 21h9M12 3c-4.97 0-9 4.03-9 9M12 3c4.97 0 9 4.03 9 9"/>
              </svg>
              <span class="text-sm font-medium text-white">Bientôt sur App Store</span>
            </button>
          </div>
          <p class="mt-5 text-xs text-neutral-500">iOS — bientôt disponible. Contactez-nous pour rejoindre le programme bêta.</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center backdrop-blur-sm">
          <img src="/android-robot.png" alt="Android" class="mx-auto mb-4 w-20" />
          <p class="text-sm text-neutral-300">Rejoignez la liste d'attente</p>
          <a href="/fr/contact"
            class="mt-4 inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-6 py-3 text-sm font-bold text-neutral-900 transition hover:bg-cyan-400">
            Nous contacter →
          </a>
        </div>
      </div>
    </div>
  </div>

</MainLayout>
